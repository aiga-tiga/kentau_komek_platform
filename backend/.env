# Copy this file to .env and fill in real values before running.

# Port for the REST API
PORT=4000

# Postgres connection string. When running via docker-compose, "db" is the
# service name in docker-compose.yml. When running locally without Docker,
# point this at your own Postgres instance.
DATABASE_URL=postgres://postgres:postgres@localhost:5432/complaints

# Secret used to sign employee login JWTs - change this to a long random string
JWT_SECRET=change-this-to-a-long-random-strings2026

# Telegram bot token from @BotFather - required only for bot/bot.js
TELEGRAM_BOT_TOKEN=8833731649:AAHtwRcNoCusrar5BCETBPD1j2XCiwE4d1k

# Optional shared secret the bot sends when creating complaints, so the
# create-complaint endpoint isn't fully open. Leave blank to disable the check.
BOT_SHARED_SECRET=optional-shared-secret-between-bot-and-api

# Base URL where the backend API is reachable from the bot process
API_BASE_URL=http://localhost:4000/api

# Where uploaded photos are written to disk. Photo URLs served to the
# frontend are relative (see backend/storage.js), so this no longer needs to
# match a public domain for that purpose.
UPLOAD_DIR=./uploads

# Public URL where the frontend is reachable (e.g. https://complaints.yourdomain.kz).
# Used to build the "check your complaint status" link sent by SMS.
PUBLIC_BASE_URL=http://78.17.7.74

# smsc.kz credentials, for the SMS sent to citizens with their complaint code
# + access code. Leave blank to disable SMS sending (it'll just log to the
# console instead) - see backend/sms.js to swap in a different provider.
